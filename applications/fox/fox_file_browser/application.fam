App(
    appid="ffb",
    name="Fox File Browser",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="ffb_app",
    requires=[
        "gui",
        "storage",
        "dialogs",
    ],
    stack_size=3 * 1024,
    fap_category="Settings",
    fap_version="1.0",
    fap_description="Browse files and install firmware updates",
    fap_author="FoxFW Team",
    fap_icon="icon.png",
    fap_icon_assets="images",
    sources=["*.c*"],
    order=10,
)
